static void UART_StartRxIT(void)
{
  HAL_UART_Receive_IT(&huart2, &uartRxByte, 1U);
}

/*
   Logical solenoid numbering preserved from your previous working version:
   1 -> output 1
   2 -> output 5
   3 -> output 4
   4 -> output 3
   5 -> output 2
*/
static uint8_t Solenoid_MapBit(uint8_t logicalIndex)
{
  static const uint8_t map[NUM_SOLENOIDS] = {0U, 4U, 3U, 2U, 1U};

  if (logicalIndex < NUM_SOLENOIDS)
  {
    return map[logicalIndex];
  }

  return logicalIndex;
}

static void Solenoid_WriteMask(uint8_t mask)
{
  SR595_Write(&hsr, mask);
}

static void Solenoid_Select(uint8_t selection)
{
  if (selection == 0U)
  {
    solenoidState = 0U;
    Solenoid_WriteMask(0U);
  }
  else if (selection <= NUM_SOLENOIDS)
  {
    uint8_t physicalBit = Solenoid_MapBit((uint8_t)(selection - 1U));
    solenoidState = selection;
    Solenoid_WriteMask((uint8_t)(1U << physicalBit));
  }
}

static void Process_Command(char *cmd)
{
  if (strncmp(cmd, "SL=", 3) == 0)
  {
    int value = atoi(&cmd[3]);

    if ((value >= 0) && (value <= (int)NUM_SOLENOIDS))
    {
      Solenoid_Select((uint8_t)value);
    }
  }
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART2)
  {
    if (uartRxByte == '!')
    {
      uartRxBuf[uartRxIdx] = '\0';
      Process_Command(uartRxBuf);
      uartRxIdx = 0U;
    }
    else if ((uartRxByte != '\r') && (uartRxByte != '\n'))
    {
      if (uartRxIdx < (UART_RX_BUF_LEN - 1U))
      {
        uartRxBuf[uartRxIdx++] = (char)uartRxByte;
      }
      else
      {
        uartRxIdx = 0U;
      }
    }

    UART_StartRxIT();
  }
}

void HAL_UART_ErrorCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART2)
  {
    uartRxIdx = 0U;
    UART_StartRxIT();
  }
}

